# ─── REQUIRED ─────────────────────────────────────

# OpenAI API key (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-...

# ─── OPTIONAL ─────────────────────────────────────

# Zapier MCP token for Gmail automation (https://zapier.com/apps/mcp)
# Without it, Gmail tools are disabled.
ZAPIER_MCP_TOKEN=

# PostgreSQL — Docker Compose overrides DB_HOST to "postgres" internally
DB_HOST=localhost
DB_PORT=5432
DB_NAME=deepagents-playground
DB_USER=postgres
DB_PASSWORD=deepagents-playground
DB_SCHEMA=public

# Ollama embedding model (used by ChromaDB)
EMBEDDINGS_MODEL=qwen3-embedding:latest
OLLAMA_BASE_URL=http://localhost:11434

# Frontend defaults for Docker/local quick start
NEXT_PUBLIC_LANGGRAPH_DEPLOYMENT_URL=http://localhost:8123
NEXT_PUBLIC_ASSISTANT_ID=sample_agent

# LangSmith tracing (optional — https://smith.langchain.com)
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=deepagents-playground
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# Optional public LangSmith key for the browser UI only.
# Leave empty unless your LangGraph deployment requires a public client key.
NEXT_PUBLIC_LANGSMITH_API_KEY=

# Backend server
SERVER_HOST=0.0.0.0
SERVER_PORT=8123
LANGGRAPH_DEPLOYMENT_URL=http://127.0.0.1:8123
